rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tras cambiar reglas: firebase deploy --only firestore:rules
    // Caja (cajaEstado/cajaSesiones): requiere documento users/{uidAuth} con role "admin"
    // o sucursalId igual al id de la tienda (ej. Matriz). Sin perfil en users → permission-denied.

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    // Incluye mayúsculas: si en users/{uid} el role quedó como "Admin", antes fallaba la comparación estricta.
    function isAdmin() {
      return userExists()
        && userData().role is string
        && (
          userData().role == 'admin'
          || userData().role == 'Admin'
          || userData().role == 'ADMIN'
          || userData().role == 'administrador'
          || userData().role == 'Administrador'
          || userData().role == 'ADMINISTRADOR'
        );
    }

    function userSucursalId() {
      return userData().sucursalId;
    }

    function canAccessSucursal(sid) {
      return userExists() && (isAdmin() || userSucursalId() == sid);
    }

    function validUserRole(r) {
      return r == 'admin'
        || r == 'gerente'
        || r == 'cashier'
        || r == 'Administrador'
        || r == 'administrador'
        || r == 'ADMINISTRADOR';
    }

    // Perfil: lectura propia o admin. Alta/edición de perfiles solo admin (app: UserManagement + REST signUp).
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'email',
          'username',
          'name',
          'role',
          'isActive',
          'sucursalId',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.username is string
        && validUserRole(request.resource.data.role)
        && request.resource.data.isActive is bool
        && (request.resource.data.sucursalId == null || request.resource.data.sucursalId is string)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'username', 'email', 'role', 'isActive', 'sucursalId', 'updatedAt', 'useCustomPermissions', 'customPermissions'])
        && validUserRole(request.resource.data.role)
        && request.resource.data.updatedAt == request.time
        && (!request.resource.data.keys().hasAny(['useCustomPermissions'])
            || request.resource.data.useCustomPermissions is bool)
        && (!request.resource.data.keys().hasAny(['customPermissions'])
            || request.resource.data.customPermissions is list);

      allow delete: if false;
    }

    // Metadatos de sucursal (mismo id que subcolecciones products/sales). Listado para selector admin.
    match /sucursales/{sucursalId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      // Traspaso TTS: la tienda destino puede marcar como recibido el doc de salida en la tienda origen.
      match /outgoingTransfers/{tid} {
        allow read: if userExists() && (
          canAccessSucursal(sucursalId)
          || resource.data.destinoSucursalId == userSucursalId()
        );
        allow create: if canAccessSucursal(sucursalId);
        allow update: if userExists() && (
          (canAccessSucursal(sucursalId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['estado', 'recibidaAt', 'recibidaPorUserId', 'recibidaPorNombre', 'updatedAt']))
          || (
            resource.data.destinoSucursalId == userSucursalId()
            && resource.data.estado == 'pendiente'
            && request.resource.data.estado == 'recibida'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['estado', 'recibidaAt', 'recibidaPorUserId', 'recibidaPorNombre', 'updatedAt'])
          )
        );
        allow delete: if false;
      }

      match /incomingTransfers/{tid} {
        allow read: if canAccessSucursal(sucursalId);
        allow create: if canAccessSucursal(sucursalId);
        allow update: if canAccessSucursal(sucursalId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['estado', 'recibidaAt', 'recibidaPorUserId', 'recibidaPorNombre', 'updatedAt']);
        allow delete: if false;
      }

      match /products/{productId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }
      match /sales/{saleId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }
      match /inventoryMovements/{movId} {
        allow read: if canAccessSucursal(sucursalId);
        allow create: if canAccessSucursal(sucursalId);
        allow update: if canAccessSucursal(sucursalId);
        allow delete: if isAdmin() && canAccessSucursal(sucursalId);
      }
      match /counters/{counterId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }

      match /cajaEstado/{docId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }

      match /cajaSesiones/{sesionId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }

      match /clients/{clientId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }

      // Configuración fiscal CFDI (misma sucursal en todos los dispositivos)
      match /config/{docId} {
        allow read, write: if canAccessSucursal(sucursalId);
      }
    }

    // Auditoría / panel de eventos (append-only para usuarios autenticados; vaciar solo admin).
    match /appEvents/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // docId = {firebaseUid}_{YYYY-MM-DD}. La lectura NO puede depender de resource.data cuando el doc
    // aún no existe (primer día sin fichar); si no, onSnapshot falla con permission-denied en bucle.
    match /checadorRegistros/{docId} {
      allow read: if signedIn() && (
        isAdmin()
        || docId.matches('^' + request.auth.uid + '_.+')
      );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && docId == request.auth.uid + '_' + request.resource.data.dateKey;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && docId == request.auth.uid + '_' + resource.data.dateKey;
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
