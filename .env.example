# Supabase (cliente PWA — solo anon key en el navegador)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dominio corporativo para login corto (ej. usuario → usuario@dominio)
VITE_SERVIPARTZ_EMAIL_DOMAIN=servipartz.com

# Multi-sucursal: ids separados por coma (deben coincidir con filas `public.sucursales.id`).
# VITE_DEFAULT_SUCURSAL_ID debe ser uno de la lista (fallback admin / migración Dexie).
VITE_SUCURSAL_IDS=principal,sucursal_2
VITE_DEFAULT_SUCURSAL_ID=principal

# ETL / import masivo (solo en su PC o CI; nunca commitear la service role key)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Producción (Vercel, etc.): mismas variables VITE_* en el panel del host. Vea docs/VERCEL.md
# Comprobación local: npm run verify:supabase
